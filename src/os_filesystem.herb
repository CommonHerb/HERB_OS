# =============================================================================
# OS EXPERIMENT 2: FILE SYSTEM AS FACTS
# =============================================================================
# Modeling files, directories, permissions, and operations as facts.
#
# Goal: See if HERB can express:
# - Hierarchical directory structure
# - File metadata (size, type, timestamps)
# - Permissions (owner, group, mode)
# - Operations: open(), read(), write(), close()
# - File locks and concurrent access
#
# Key questions:
# - Can directory containment be modeled cleanly?
# - How do file operations work as state transitions?
# - What about locks? Multiple readers, single writer?
# =============================================================================

# --- Functional relations ---
FUNCTIONAL parent         # Each file/dir has exactly one parent (except root)
FUNCTIONAL size           # File size
FUNCTIONAL owner          # File owner
FUNCTIONAL group          # File group
FUNCTIONAL mode           # Permission bits (simplified)
FUNCTIONAL modified_at    # Last modification tick
FUNCTIONAL created_at     # Creation tick
FUNCTIONAL content        # For simplicity, content is a single value (real FS: blocks)
FUNCTIONAL lock_holder    # If locked exclusively, who holds it

# --- Multi-valued (intentional) ---
# (file reader ?proc) - multiple concurrent readers allowed
# (dir contains ?child) - directories contain multiple children

# =============================================================================
# INITIAL STATE: BASIC FILE SYSTEM
# =============================================================================

# Root directory
FACT root is_a directory
FACT root name "/"
# root has no parent (special case)

# Home directory
FACT home is_a directory
FACT home name "home"
FACT home parent root
FACT root contains home
FACT home owner alice
FACT home group users
FACT home mode 755

# Alice's home
FACT alice_home is_a directory
FACT alice_home name "alice"
FACT alice_home parent home
FACT home contains alice_home
FACT alice_home owner alice
FACT alice_home group users
FACT alice_home mode 700

# A file in alice's home
FACT notes_txt is_a file
FACT notes_txt name "notes.txt"
FACT notes_txt parent alice_home
FACT alice_home contains notes_txt
FACT notes_txt owner alice
FACT notes_txt group users
FACT notes_txt mode 644
FACT notes_txt size 1024
FACT notes_txt content "Hello World"
FACT notes_txt created_at 0
FACT notes_txt modified_at 0

# Another file
FACT config_txt is_a file
FACT config_txt name "config.txt"
FACT config_txt parent alice_home
FACT alice_home contains config_txt
FACT config_txt owner alice
FACT config_txt group users
FACT config_txt mode 600
FACT config_txt size 256
FACT config_txt content "secret=12345"
FACT config_txt created_at 0
FACT config_txt modified_at 0

# =============================================================================
# USERS AND PROCESSES
# =============================================================================

FACT alice is_a user
FACT alice primary_group users
FACT alice member_of users
FACT alice member_of developers

FACT bob is_a user
FACT bob primary_group users
FACT bob member_of users

FACT proc1 is_a process
FACT proc1 run_as alice

FACT proc2 is_a process
FACT proc2 run_as bob

# =============================================================================
# PERMISSION RULES
# =============================================================================

# Check if user is file owner
RULE check_owner
  WHEN ?file owner ?user
  AND ?user is_a user
  THEN ?user is_owner_of ?file

# Check if user is in file's group
RULE check_group
  WHEN ?file group ?grp
  AND ?user member_of ?grp
  THEN ?user in_group_of ?file

# Simplified permission check: owner can do anything
RULE owner_can_read
  WHEN ?user is_owner_of ?file
  THEN ?user can_read ?file

RULE owner_can_write
  WHEN ?user is_owner_of ?file
  THEN ?user can_write ?file

# Group members can read if group-readable (mode check would need arithmetic)
# PROBLEM: Mode 644 means (mode & 040) != 0 for group read. Bit operations!
# HERB has mod (modulo) but not bitwise AND. Would need to decompose mode.

# For now, hardcode: if mode >= 640 and user in group, can read
# This is a hack. Real permission checks need bitwise ops.

RULE group_can_read_hack
  WHEN ?file mode ?m
  AND ?user in_group_of ?file
  IF (>= ?m 640)
  THEN ?user can_read ?file

# World-readable: mode >= 644
RULE world_can_read_hack
  WHEN ?file mode ?m
  AND ?user is_a user
  IF (>= ?m 644)
  THEN ?user can_read ?file

# =============================================================================
# FILE OPERATIONS AS STATE TRANSITIONS
# =============================================================================

# Request to open file for reading
# External event: process asserts (proc1 open_request notes_txt read)

# RULE: Grant open if permitted and not exclusively locked
RULE grant_open_read
  WHEN ?proc open_request ?file read
  AND ?proc run_as ?user
  AND ?user can_read ?file
  IF (not-exists (?file lock_holder ?any))
  THEN ?proc has_open_fd ?file read
  RETRACT ?proc open_request ?file read

# Add as reader (multiple allowed)
RULE add_reader
  WHEN ?proc has_open_fd ?file read
  THEN ?file reader ?proc

# Request to open for writing (needs exclusive access)
RULE grant_open_write
  WHEN ?proc open_request ?file write
  AND ?proc run_as ?user
  AND ?user can_write ?file
  IF (not-exists (?file lock_holder ?any))
  IF (not-exists (?file reader ?any))
  THEN ?proc has_open_fd ?file write
  AND ?file lock_holder ?proc
  RETRACT ?proc open_request ?file write

# =============================================================================
# CLOSE OPERATIONS
# =============================================================================

# Close read handle
RULE close_read
  WHEN ?proc close_request ?file read
  AND ?proc has_open_fd ?file read
  THEN ?proc closed_fd ?file read
  RETRACT ?proc has_open_fd ?file read
  RETRACT ?file reader ?proc
  RETRACT ?proc close_request ?file read

# Close write handle (release lock)
RULE close_write
  WHEN ?proc close_request ?file write
  AND ?proc has_open_fd ?file write
  AND ?file lock_holder ?proc
  THEN ?proc closed_fd ?file write
  RETRACT ?proc has_open_fd ?file write
  RETRACT ?file lock_holder ?proc
  RETRACT ?proc close_request ?file write

# =============================================================================
# WRITE OPERATION (sketch)
# =============================================================================

# Process with write fd can submit write
