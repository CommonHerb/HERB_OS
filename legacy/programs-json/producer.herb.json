{
  "tensions": [
    {
      "name": "produce",
      "priority": 6,
      "match": [
        {"bind": "me", "in": "proc.CPU0",
         "where": {"op": "<", "left": {"prop": "produced", "of": "me"}, "right": {"prop": "produce_limit", "of": "me"}}},
        {"bind": "buf", "in": "BUFFER",
         "where": {"op": "<", "left": {"prop": "count", "of": "buf"}, "right": {"prop": "capacity", "of": "buf"}}}
      ],
      "emit": [
        {"set": "buf", "property": "count",
         "value": {"op": "+", "left": {"prop": "count", "of": "buf"}, "right": 1}},
        {"set": "me", "property": "produced",
         "value": {"op": "+", "left": {"prop": "produced", "of": "me"}, "right": 1}}
      ]
    }
  ]
}
