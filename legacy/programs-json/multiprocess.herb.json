        "container": "FD_FREE"
      }
    },
    {
      "name": "fd1_A",
      "type": "FileDescriptor",
      "in": {
        "scope": "proc_A",
        "container": "FD_FREE"
      }
    },
    {
      "name": "fd2_A",
      "type": "FileDescriptor",
      "in": {
